---
// Import GSAP
import { onMount } from 'svelte';
import { useEffect } from 'react'; // or use your framework's lifecycle
---

<div class="astronomy-gallery-container">
  <div class="gallery-sidebar">
    <div class="gallery-title">Astronomy Gallery</div>
    <div class="gallery-items-container" id="gallery-container">
      {#each galleryItems as item}
        <div 
          class="gallery-item"
          data-slug={item.slug}
          data-index={item.index}
        >
          <div class="item-overlay">
            <div class="item-title">{item.title}</div>
            <div class="item-date">{item.date}</div>
          </div>
          <img 
            src={item.thumbnail} 
            alt={item.title}
            class="gallery-image"
          />
        </div>
      {/each}
    </div>
  </div>
</div>

<style>
.astronomy-gallery-container {
  position: fixed;
  right: 0;
  top: 0;
  height: 100vh;
  width: 300px;
  z-index: 1000;
  background: rgba(10, 10, 30, 0.9);
  backdrop-filter: blur(10px);
  border-left: 1px solid rgba(255, 255, 255, 0.1);
}

.gallery-sidebar {
  height: 100%;
  overflow-y: auto;
  padding: 20px;
}

.gallery-title {
  color: #fff;
  font-size: 1.5rem;
  margin-bottom: 20px;
  text-align: center;
  font-weight: 300;
  letter-spacing: 1px;
}

.gallery-items-container {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.gallery-item {
  position: relative;
  height: 120px;
  border-radius: 8px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
  transform: scale(1);
}

.gallery-item:hover {
  transform: scale(1.02);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
}

.gallery-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.gallery-item:hover .gallery-image {
  transform: scale(1.1);
}

.item-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
  padding: 10px;
  color: white;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.gallery-item:hover .item-overlay {
  opacity: 1;
}

.item-title {
  font-size: 0.9rem;
  font-weight: 500;
  margin-bottom: 5px;
}

.item-date {
  font-size: 0.7rem;
  opacity: 0.8;
}
</style>
