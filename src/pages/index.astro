---

<RootLayout>
	<main>
		<div class="group relative w-full min-h-dvh flex items-center justify-center">
			<div class="absolute w-full h-dvh -z-10">
				<WarpBackground
					color1= #111111
					color2= #222222
					color3= #B3402E
					speed={0.4}
					swirl={0.4}
					swirlIterations={10}
					shapeScale={0.3}
					client:load
				/>
			</div>

			<div class="p-10 sm:p-8 absolute w-full h-dvh flex flex-col justify-between z-10">
				<div>
					<H1 size="large"> Liam Lyons IV<br /> Portfolio </H1>
				</div>

				<div>
					<AvailableForWork className="py-4" />
					<div class="mb-2 sm:mb-4 flex items-center justify-between">
						<div class="flex items-center gap-4">
							<Link href="/work">Collection</Link>
							<Link href="/work?category=lighting%20design" variant="secondary">Lighting Design</Link>
							<Link href="/work?category=touring" variant="secondary">Touring</Link>
							<Link href="/work?category=videography" variant="secondary">Videography</Link>
							
						</div>

						<Navigation client:load>
							<Link href="/about" variant="secondary">About</Link>
							<Link href="/contact" variant="secondary">Contact</Link>
						</Navigation>
					</div>
				</div>
			</div>







		</div>
			
	</main>
</RootLayout>
