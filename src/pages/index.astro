---
import H1 from "../components/h1.astro";
import Link from "../components/link.astro";
import Navigation from "../components/navigation";
import RootLayout from "../layouts/RootLayout.astro";
import WarpBackground from "../components/warp-background";
import AvailableForWork from "../components/available.astro";
// import { getCollection } from "astro:content";
// import AstronomyGallery from '../components/AstronomyGallery.astro';
// import { setupGallery } from '../lib/gallery-animation.js';
// import { onMount } from 'svelte';

// Get all articles for the slideshow
// const allArticles = await getCollection("articles");
// const filteredArticles = allArticles.filter(article => !article.data.isDraft);
// const sortedArticles = filteredArticles.sort((a, b) => {
//     return new Date(b.data.pubDate) - new Date(a.data.pubDate);
