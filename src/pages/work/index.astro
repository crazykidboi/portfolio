---
import clsx from "clsx";
import { getCollection } from "astro:content";
import H1 from "../../components/h1.astro";
import { formatDate } from "../../lib/utils";
import InfoLayout from "../../layouts/InfoLayout.astro";


// 1. Fetch all articles natively instead of using backend Actions
const allArticles = await getCollection("articles");

// 2. Filter out drafts and sort them by date
const articles = allArticles
    .filter(article => !article.data.isDraft)
    .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

// 3. Extract unique categories dynamically from your articles
const categories = [...new Set(articles.map(article => article.data.category))].filter(Boolean);
---

<InfoLayout>
    <div class="p-5 sm:pt-8 sm:px-12 pb-20 min-h-dvh">
        <H1> Work </H1>

        <ul class="mt-6 flex items-center gap-4" id="category-nav">
            <li>
                <a href="/work" data-category="all" class="category-link w-fit px-4 py-1 text-sm bg-transparent rounded-full transition-all duration-300 ease-in-out text-white bg-zinc-100/20 outline-2 outline-offset-2 outline-zinc-100/20">
                    All
                </a>
            </li>
            {
                categories.map((category) => (
                    <li>
                        <a
                            href={`/work?category=${category.toLowerCase()}`}
                            data-category={category.toLowerCase()}
                            class="category-link w-fit px-3 py-1 text-sm md:text-lg bg-transparent rounded-full transition-all duration-300 ease-in-out text-zinc-400 hover:text-zinc-200"
                        >
                            {category}
                        </a>
                    </li>
                ))
            }
        </ul>

        <ul class="grid max-w-300 grid-cols-2 md:grid-cols-3 gap-6 mt-3 space-y-2" id="portfolio-grid">
            {
                articles.map((article) => (
                    // We attach the category as a data attribute for our script to read
                    <li class="portfolio-item" data-category={article.data.category?.toLowerCase()}>
                        <a
                            class="space-y-0.8 group max-w-300"
                            href={`/work/${article.data.slug}`}
                        >
                            <h2 class="text-lg text-zinc-300 group-hover:text-white text-balance underline group-hover:underline-offset-2 decoration-transparent group-hover:decoration-zinc-500">
                                {article.data.title}
                            </h2>
                        
                            <p class="text-sm text-zinc-500 italic">
                                {formatDate(article.data.pubDate)} &middot;{" "}
                                {article.data.mainRole} &middot;{" "}
                                {article.data.company}
                            </p>
                            <img src={article.data.cover} class="w-300 aspect-3/4 h-auto overflow-hidden object-cover rounded-lg"/>
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
</InfoLayout>

<script>
    // 1. Extract the filtering logic into a reusable function
    function filterPortfolio(category) {
        // Update active state on links
        document.querySelectorAll('.category-link').forEach(link => {
            if (link.dataset.category === category) {
                link.classList.add('text-white', 'bg-zinc-100/20', 'outline-2', 'outline-offset-2', 'outline-zinc-100/20');
                link.classList.remove('text-zinc-400', 'hover:text-zinc-200');
            } else {
                link.classList.remove('text-white', 'bg-zinc-100/20', 'outline-2', 'outline-offset-2', 'outline-zinc-100/20');
                link.classList.add('text-zinc-400', 'hover:text-zinc-200');
            }
        });

        // Hide or show the portfolio items
        document.querySelectorAll('.portfolio-item').forEach(item => {
            if (category === "all" || item.dataset.category === category) {
                item.style.display = "block";
            } else {
                item.style.display = "none";
            }
        });
    }

    // 2. Run the filter immediately when the page first loads
    const initialParams = new URLSearchParams(window.location.search);
    const initialCategory = initialParams.get("category") || "all";
    filterPortfolio(initialCategory);

    // 3. Listen for clicks on the category buttons
    document.querySelectorAll('.category-link').forEach(link => {
        link.addEventListener('click', (e) => {
            e.preventDefault(); // Stop the browser from trying to reload the page
            
            const selectedCategory = link.dataset.category;
            
            // Update the URL bar silently so it looks nice
            const url = new URL(link.href);
            history.pushState(null, '', url);

            // Run our instant filter!
            filterPortfolio(selectedCategory);
        });
    });

    // 4. Make sure the browser's Back/Forward buttons still work
    window.addEventListener('popstate', () => {
        const params = new URLSearchParams(window.location.search);
        const category = params.get("category") || "all";
        filterPortfolio(category);
    });
</script>