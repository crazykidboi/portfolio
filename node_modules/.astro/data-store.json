if\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_002.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_004.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_005.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_006.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_007.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_008.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_009.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_010.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_011.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_012.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_013.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_014.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_015.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/fresh_ricki/Rickia_016.avif\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cem>Photos by \u003Ca href=\"https://kelly-strayhorn.org\">Kelly-Strayhorn Theater\u003C/a>\u003C/em>\u003C/p>",{"headings":52,"localImagePaths":56,"remoteImagePaths":57,"frontmatter":58,"imagePaths":60},[53],{"depth":19,"slug":54,"text":55},"freshworks-rickia-davenport---the-choice","Freshworks: Rickia Davenport - The Choice",[],[],{"isDraft":21,"title":42,"snippet":16,"slug":39,"mainRole":17,"company":22,"category":17,"readingDuration":19,"pubDate":59,"coverAlt":14,"originalLink":44,"cover":45},"2025 11 7",[],"sum-of-yall",{"id":61,"data":63,"body":71,"filePath":72,"digest":73,"rendered":74},{"coverAlt":64,"title":65,"slug":61,"snippet":66,"category":17,"pubDate":67,"readingDuration":19,"originalLink":68,"isDraft":21,"mainRole":17,"company":69,"cover":70},"Women Holding Things - Maira Kalman, 2022.","Sum of Y'all","We're creating more than ever, but it weighs nothing.",["Date","2025-03-09T05:00:00.000Z"],"https://www.workingtheorys.com/p/make-something-heavy","Pearl Arts","/workPhotos/Sum_1.jpg","# Sum of Y'all\n\nI had never known about \u003Ca href=\"https://www.pearlartsmovement.org\">Pearl Arts - Movement and Sound\u003C/a> before, but after meeting Herman and Staycee I knew it was going to be a fun project. The goal was to create a lighting, projection, sound and dance performance where each element interacted with the others. After building an updated lighting plot on, my main focus was to build cues that aligned with the beautiful projections of \u003Ca href=\"https://stage.scottnandrew.com/statement\">Scott Andrew\u003C/a>. The process involved working section by section with Andrew so that each video had corresponding lighting; matching hues, timings, and transitions. Around tech week we met the rest of the team and the dancers, all of which were great at what they did and were always ready to work with any tech issues we came across. In the end the show went great, we sold out nearly every show!\n\n\u003Cdiv style=\"position: relative; width: 100%; height: 0; padding-bottom: 56.25%;\">\n  \u003Ciframe \n    src=\"https://www.youtube.com/embed/gEQPG_13CnE?autoplay=1&mute=1&loop=1&playlist=gEQPG_13CnE&controls=0&modestbranding=1&rel=0&showinfo=0&iv_load_policy=3&disablekb=1&fs=0&playsinline=1\" \n    title=\"YouTube video player\" \n    style=\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;\"\n    allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" \n    allowfullscreen\n  >\u003C/iframe>\n\u003C/div>\n\n![image](/workPhotos/sum_011.jpg)\n*Photos by Liam Lyons IV*\n\n![image](/workPhotos/Sum_2.jpg)\n*Poster by Pearl Arts*\n\n![image](/workPhotos/sum_004.jpg)\n\n![image](/workPhotos/sum_006.jpg)\n\n![image](/workPhotos/sum_010.jpg)\n\n![image](/workPhotos/sum_014.jpg)","src/content/articles/25-3-28_SumOfYall.md","7cce388faa1d011c",{"html":75,"metadata":76},"\u003Ch1 id=\"sum-of-yall\">Sum of Y’all\u003C/h1>\n\u003Cp>I had never known about \u003Ca href=\"https://www.pearlartsmovement.org\">Pearl Arts - Movement and Sound\u003C/a> before, but after meeting Herman and Staycee I knew it was going to be a fun project. The goal was to create a lighting, projection, sound and dance performance where each element interacted with the others. After building an updated lighting plot on, my main focus was to build cues that aligned with the beautiful projections of \u003Ca href=\"https://stage.scottnandrew.com/statement\">Scott Andrew\u003C/a>. The process involved working section by section with Andrew so that each video had corresponding lighting; matching hues, timings, and transitions. Around tech week we met the rest of the team and the dancers, all of which were great at what they did and were always ready to work with any tech issues we came across. In the end the show went great, we sold out nearly every show!\u003C/p>\n\u003Cdiv style=\"position: relative; width: 100%; height: 0; padding-bottom: 56.25%;\">\n  \u003Ciframe src=\"https://www.youtube.com/embed/gEQPG_13CnE?autoplay=1&#x26;mute=1&#x26;loop=1&#x26;playlist=gEQPG_13CnE&#x26;controls=0&#x26;modestbranding=1&#x26;rel=0&#x26;showinfo=0&#x26;iv_load_policy=3&#x26;disablekb=1&#x26;fs=0&#x26;playsinline=1\" title=\"YouTube video player\" style=\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen>\u003C/iframe>\n\u003C/div>\n\u003Cp>\u003Cimg src=\"/workPhotos/sum_011.jpg\" alt=\"image\">\n\u003Cem>Photos by Liam Lyons IV\u003C/em>\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/Sum_2.jpg\" alt=\"image\">\n\u003Cem>Poster by Pearl Arts\u003C/em>\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/sum_004.jpg\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/sum_006.jpg\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/sum_010.jpg\" alt=\"image\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/workPhotos/sum_014.jpg\" alt=\"image\">\u003C/p>",{"headings":77,"localImagePaths":80,"remoteImagePaths":81,"frontmatter":82,"imagePaths":84},[78],{"depth":19,"slug":61,"text":79},"Sum of Y’all",[],[],{"isDraft":21,"title":65,"snippet":66,"slug":61,"mainRole":17,"company":69,"category":17,"readingDuration":19,"pubDate":83,"coverAlt":64,"originalLink":68,"cover":70},"2025 3 9",[],"we_cross_the_river",{"id":85,"data":87,"body":94,"filePath":95,"digest":96,"rendered":97},{"coverAlt":14,"title":88,"slug":85,"snippet":16,"category":89,"pubDate":90,"readingDuration":19,"originalLink":20,"isDraft":21,"mainRole":91,"company":92,"cover":93},"We Cross the River","Touring",["Date","2025-05-31T04:00:00.000Z"],"Media Technician","Kamraton","/workPhotos/kat.JPG","# We Cross the River\n\nI had the pleasure or working with Media Designer Aaron Henderson to sync visual text with live vocalists. I created Qlab scripts to achieve this, decreasing and increasing video speed using midi triggers, this was crucial in making sure the lyrics aligned with the vocalists on stage. There were two shows, one at Chatham University in Pittsburgh, and another at the National Opera House in New York City.\n\n![image](/workPhotos/kat2.jpeg)\n*Photo by \u003Ca href=\"https://www.facebook.com/Kamraton/\">Kamraton\u003C/a>*\n\n\u003Cdiv style=\"position: relative; width: 100%; height: 0; padding-bottom: 56.25%;\">\n  \u003Ciframe \n    src=\"https://www.youtube.com/embed/lqeMg32qTec?autoplay=1&mute=1&loop=1&playlist=lqeMg32qTec&controls=0&modestbranding=1&rel=0&showinfo=0&iv_load_policy=3&disablekb=1&fs=0&playsinline=1\" \n    title=\"YouTube video player\" \n    style=\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;\"\n    allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" \n    allowfullscreen\n  >\u003C/iframe>\n\u003C/div>\n\n\u003Cdiv style=\"position: relative; width: 100%; height: 0; padding-bottom: 56.25%;\">\n  \u003Ciframe \n    src=\"https://www.youtube.com/embed/Tgp0oKLlljw?autoplay=1&mute=1&loop=1&playlist=Tgp0oKLlljw&controls=0&modestbranding=1&rel=0&showinfo=0&iv_load_policy=3&disablekb=1&fs=0&playsinline=1\" \n    title=\"YouTube video player\" \n    style=\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;\"\n    allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" \n    allowfullscreen\n  >\u003C/iframe>\n\u003C/div>\n\n\u003Cdiv style=\"position: relative; width: 100%; height: 0; padding-bottom: 56.25%;\">\n  \u003Ciframe \n    src=\"https://www.youtube.com/embed/DQYJjoRYCJU?autoplay=1&mute=1&loop=1&playlist=DQYJjoRYCJU&controls=0&modestbranding=1&rel=0&showinfo=0&iv_load_policy=3&disablekb=1&fs=0&playsinline=1\" \n    title=\"YouTube video player\" \n    style=\"position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none;\"\n    allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" \n    allowfullscreen\n  >\u003C/iframe>\n\u003C/div>\n\n![image](/workPhotos/kat.JPG)","src/content/articles/25-5-31_WeCrossTheRiver.md","919c99c08202a9dc",{"html":98,"metadata":99},"\u003Ch1 id=\"we-cross-the-river\">We Cross the River\u003C/h1>\n\u003Cp>I had the pleasure or working with Media Designer Aaron Henderson to sync visual text with live vocalists. I created Qlab scripts to achieve this, decreasing and increasing video speed using midi triggers, this was crucial in making sure the lyrics aligned with the vocalists on stage. There were two shows, one at Chatham University in Pittsburgh, and another at the National Opera House in New York City.\u003C/p>\n\u003Cp>\u